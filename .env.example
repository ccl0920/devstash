# Database
# Neon PostgreSQL connection string (serverless)
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/devstash?sslmode=require"

